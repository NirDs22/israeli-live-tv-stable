<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.israeli.live.tv.stable" name="Israeli Live TV Stable" version="0.1.10" provider-name="Israeli Live TV Stable">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="inputstream.adaptive" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.service" library="resources/lib/service.py" start="login"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Stable live-TV-only Israeli channel browser.</summary>
    <description lang="en">A lightweight live-TV-only addon that plays verified or user-configured legal sources and explains clearly when playback is unavailable.</description>
    <platform>all</platform>
    <license>MIT</license>
    <assets>
      <icon>resources/data/logos/icon.png</icon>
      <fanart>resources/data/logos/fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
